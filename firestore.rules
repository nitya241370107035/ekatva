rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{uid} {
      allow read, write: if true;
    }
    match /weavers/{uid} {
      allow read, write: if true;
    }
    match /cooperatives/{coopId} {
      allow read, write: if true;
    }
    match /notices/{noticeId} {
      allow read, write: if true;
    }
    match /meetings/{meetingId} {
      allow read, write: if true;
    }
    match /grievances/{grievanceId} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
    match /rawMaterialStock/{stockId} {
      allow read, write: if true;
    }
    match /jobCards/{jobCardId} {
      allow read, write: if true;
      
      match /statusLog/{logId} {
        allow read, write: if true;
      }
    }
    match /indentRequests/{requestId} {
      allow read, write: if true;
    }
    match /bulkIndents/{indentId} {
      allow read, write: if true;
    }
    match /payments/{paymentId} {
      allow read, write: if true;
    }
    match /vendors/{vendorId} {
      allow read, write: if true;
    }
    match /products/{productId} {
      allow read, write: if true;
    }
    match /buyerRFQs/{rfqId} {
      allow read, write: if true;
    }
    match /coalitions/{coalitionId} {
      allow read, write: if true;
    }
    match /productInstances/{instanceId} {
      allow read, write: if true;
    }
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }
    match /test/{doc} {
      allow read, write: if true;
    }
  }
}

