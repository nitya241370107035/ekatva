rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{uid} {
      allow read, write: if true;
    }
    match /weavers/{uid} {
      allow read, write: if true;
    }
    match /cooperatives/{coopId} {
      allow read, write: if true;
    }
    match /notices/{noticeId} {
      allow read, write: if true;
    }
    match /meetings/{meetingId} {
      allow read, write: if true;
    }
    match /grievances/{grievanceId} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
    match /rawMaterialStock/{stockId} {
      allow read, write: if true;
    }
    match /jobCards/{jobCardId} {
      allow read, write: if true;
      
      match /statusLog/{logId} {
        allow read, write: if true;
      }
    }
    match /indentRequests/{requestId} {
      allow read, write: if true;
    }
    match /bulkIndents/{indentId} {
      allow read, write: if true;
    }
    match /payments/{paymentId} {
      allow read, write: if true;
    }
    match /vendors/{vendorId} {
      allow read, write: if true;
    }
    match /products/{productId} {
      allow read, write: if true;
    }
    match /buyerRFQs/{rfqId} {
      allow read, write: if true;
    }
    match /coalitions/{coalitionId} {
      allow read, write: if true;
    }
    match /productInstances/{instanceId} {
      allow read, write: if true;
    }
    match /productSubmissions/{submissionId} {
      allow read, write: if true;
      // Secure production alternative:
      // allow create: if request.auth != null && request.resource.data.weaverId == request.auth.uid;
      // allow read: if request.auth != null && (resource.data.weaverId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'secretary');
      // allow update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'secretary';
    }
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }
    match /test/{doc} {
      allow read, write: if true;
    }
  }
}

